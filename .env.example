# Discord Bot
DISCORD_TOKEN=your_discord_bot_token_here
# Optional: restrict slash-command sync to one guild during development
# DISCORD_GUILD_ID=123456789012345678

# HearthstoneJSON
HSJSON_LOCALE=enUS
# Resolution of card render images to fetch: 256x or 512x
IMAGE_CARD_SIZE=256x

# Internal cache service URL (matches docker-compose service name)
CACHE_BASE_URL=http://cache

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
