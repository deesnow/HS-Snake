# Normalize line endings to LF in the repository
* text=auto eol=lf

# Force LF for all source/config files
*.py     text eol=lf
*.md     text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.txt    text eol=lf
*.conf   text eol=lf
*.json   text eol=lf
*.env*   text eol=lf
Dockerfile text eol=lf

# Binary files — no line-ending conversion
*.png    binary
*.jpg    binary
*.jpeg   binary
*.ttf    binary
*.otf    binary
